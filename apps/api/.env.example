# apps/api environment

# Postgres connection. The role MUST NOT have BYPASSRLS — RLS is the tenant
# isolation layer and must apply to this connection.
DATABASE_URL=postgres://app_user:password@localhost:5432/aurumtrace

# Optional: SET LOCAL ROLE used per request (defaults to "authenticated").
DB_APP_ROLE=authenticated

# Supabase JWT signing secret (HS256) — used to verify access tokens.
SUPABASE_JWT_SECRET=replace-me

# Dev only: when true, accept x-debug-user / x-debug-tenant / x-debug-role headers
# instead of a real JWT. NEVER enable in any deployed environment.
AUTH_DEV_MODE=false

# Hosted OPEN DEMO (no login): every request resolves to one fixed demo tenant.
# RLS still scopes all data to that tenant. This is NOT a login path — keep it
# OFF for a real pilot. Cannot be combined with AUTH_DEV_MODE.
DEMO_MODE=false
DEMO_TENANT_ID=00000000-0000-0000-0000-0000000000a1
# DEMO_USER_ID / DEMO_ROLE have safe defaults; override only if needed.

PORT=3001
