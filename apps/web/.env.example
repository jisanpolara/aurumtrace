# apps/web environment

# AurumTrace API (NestJS). The web app calls this with the user's Supabase access
# token; the API verifies it and enforces tenant RLS. Real tenant data is only
# reachable through here — never from the browser directly.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase project (for real auth + MFA). When these are set, sign-in uses
# Supabase Auth and the app session replaces the dev stand-in cookie.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Hosted OPEN DEMO (no login): when "1", the sign-in gate is always open and a
# "DEMO — sample data" banner shows. Pair with the API's DEMO_MODE=true.
DEMO_MODE=
